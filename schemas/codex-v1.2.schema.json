{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://chapterwise.app/schemas/codex-v1.2.schema.json",
  "title": "Codex V1.2",
  "description": "ChapterWise Codex format specification v1.2 - A recursive, self-describing document format for structured creative content",
  "type": "object",

  "properties": {
    "metadata": {
      "$ref": "#/$defs/metadata"
    },
    "id": {
      "type": "string",
      "description": "Unique identifier (UUID v4 or simple slug)",
      "pattern": "^[a-zA-Z0-9_-]+$|^[0-9a-f]{8}-[0-9a-f]{4}-4[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$"
    },
    "type": {
      "type": "string",
      "description": "Node type (user-defined: chapter, character, location, recipe, etc.)",
      "minLength": 1
    },
    "name": {
      "type": "string",
      "description": "Display name"
    },
    "title": {
      "type": "string",
      "description": "Alternative title (fallback for name)"
    },
    "summary": {
      "type": "string",
      "description": "Brief one-line description"
    },
    "description": {
      "type": "string",
      "description": "Detailed description"
    },
    "body": {
      "type": "string",
      "description": "Main prose content (markdown supported)"
    },
    "status": {
      "type": "string",
      "enum": ["draft", "published", "private", "archived"],
      "description": "Publishing status"
    },
    "featured": {
      "type": "boolean",
      "description": "Whether this node is featured/highlighted"
    },
    "attributes": {
      "type": "array",
      "description": "Structured key-value metadata",
      "items": {
        "$ref": "#/$defs/attribute"
      }
    },
    "tags": {
      "type": "array",
      "description": "Searchable tags",
      "items": {
        "oneOf": [
          { "type": "string" },
          { "$ref": "#/$defs/detailedTag" }
        ]
      }
    },
    "relations": {
      "type": "array",
      "description": "Cross-references to other nodes",
      "items": {
        "$ref": "#/$defs/relation"
      }
    },
    "content": {
      "oneOf": [
        { "type": "string", "description": "Alternative prose field" },
        {
          "type": "array",
          "description": "Structured content sections",
          "items": {
            "$ref": "#/$defs/contentSection"
          }
        }
      ]
    },
    "children": {
      "type": "array",
      "description": "Child nodes (recursive structure)",
      "items": {
        "oneOf": [
          { "$ref": "#" },
          { "$ref": "#/$defs/includeDirective" }
        ]
      }
    },
    "include": {
      "type": "string",
      "description": "Path to external codex file to include",
      "pattern": "^(\\.{0,2}/|/).+\\.(codex\\.)?(yaml|yml|json|md)$"
    },
    "image": {
      "type": "string",
      "description": "Single image URL or path"
    },
    "images": {
      "type": "array",
      "description": "Image gallery",
      "items": {
        "$ref": "#/$defs/image"
      }
    },
    "external_url": {
      "type": "string",
      "format": "uri",
      "description": "External reference URL"
    },
    "color": {
      "type": "string",
      "description": "UI color identifier for visual organization"
    }
  },

  "required": ["metadata"],

  "$defs": {
    "metadata": {
      "type": "object",
      "description": "Document metadata",
      "properties": {
        "formatVersion": {
          "type": "string",
          "enum": ["1.0", "1.1", "1.2"],
          "description": "Codex format version"
        },
        "documentVersion": {
          "type": "string",
          "description": "Document version (semver recommended)",
          "pattern": "^\\d+\\.\\d+\\.\\d+(-[a-zA-Z0-9]+)?$"
        },
        "created": {
          "type": "string",
          "format": "date-time",
          "description": "Creation timestamp (ISO 8601)"
        },
        "updated": {
          "type": "string",
          "format": "date-time",
          "description": "Last update timestamp (ISO 8601)"
        },
        "author": {
          "oneOf": [
            { "type": "string" },
            { "type": "array", "items": { "type": "string" } }
          ],
          "description": "Author name(s)"
        },
        "license": {
          "type": "string",
          "description": "License identifier (e.g., MIT, CC-BY-4.0)"
        },
        "tags": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Document-level tags"
        }
      },
      "required": ["formatVersion"]
    },

    "attribute": {
      "type": "object",
      "description": "Structured key-value attribute",
      "properties": {
        "key": {
          "type": "string",
          "description": "Attribute identifier (snake_case or kebab-case, lowercase)",
          "pattern": "^[a-z][a-z0-9_-]*$"
        },
        "name": {
          "type": "string",
          "description": "Display name"
        },
        "value": {
          "description": "Attribute value (any type)"
        },
        "dataType": {
          "type": "string",
          "enum": ["string", "int", "float", "boolean", "date", "url", "markdown", "stringArray", "object"],
          "description": "Value type hint for rendering"
        },
        "id": {
          "type": "string",
          "description": "Optional unique identifier"
        },
        "type": {
          "type": "string",
          "description": "Optional attribute type"
        }
      },
      "required": ["key", "value"]
    },

    "detailedTag": {
      "type": "object",
      "description": "Tag with metadata",
      "properties": {
        "name": {
          "type": "string",
          "description": "Tag name"
        },
        "count": {
          "type": "integer",
          "description": "Occurrence count"
        }
      },
      "required": ["name"]
    },

    "relation": {
      "type": "object",
      "description": "Cross-reference to another node",
      "properties": {
        "targetId": {
          "type": "string",
          "description": "Target node ID"
        },
        "type": {
          "type": "string",
          "description": "Relation type (ally, enemy, parent, child, features, precedes, etc.)"
        },
        "kind": {
          "type": "string",
          "description": "Alternative to type for relation kind"
        },
        "strength": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Relationship strength/confidence (0-1)"
        },
        "reciprocal": {
          "type": "boolean",
          "description": "Whether relation is bidirectional"
        },
        "description": {
          "type": "string",
          "description": "Relation details"
        }
      },
      "required": ["targetId"]
    },

    "contentSection": {
      "type": "object",
      "description": "Structured content section",
      "properties": {
        "key": {
          "type": "string",
          "description": "Section identifier"
        },
        "name": {
          "type": "string",
          "description": "Display name"
        },
        "value": {
          "type": "string",
          "description": "Section content"
        },
        "content": {
          "type": "string",
          "description": "Alternative to value"
        },
        "summary": {
          "type": "string",
          "description": "Section summary"
        },
        "id": {
          "type": "string"
        },
        "type": {
          "type": "string"
        },
        "attributes": {
          "type": "array",
          "items": { "$ref": "#/$defs/attribute" }
        }
      }
    },

    "includeDirective": {
      "type": "object",
      "description": "Reference to external codex file",
      "properties": {
        "include": {
          "type": "string",
          "description": "Path to external file",
          "pattern": "^(\\.{0,2}/|/).+\\.(codex\\.)?(yaml|yml|json|md)$"
        }
      },
      "required": ["include"]
    },

    "image": {
      "type": "object",
      "description": "Image with metadata",
      "properties": {
        "url": {
          "type": "string",
          "description": "Image URL or path"
        },
        "caption": {
          "type": "string",
          "description": "Image description"
        },
        "alt": {
          "type": "string",
          "description": "Alt text for accessibility"
        }
      },
      "required": ["url"]
    }
  },

  "examples": [
    {
      "metadata": {
        "formatVersion": "1.2",
        "documentVersion": "1.0.0",
        "created": "2026-02-02T12:00:00Z",
        "author": "Jane Author"
      },
      "id": "my-novel",
      "type": "book",
      "name": "The Great Adventure",
      "summary": "A tale of courage and discovery",
      "status": "draft",
      "attributes": [
        { "key": "genre", "value": "fantasy", "dataType": "string" },
        { "key": "word_count", "value": 85000, "dataType": "int" }
      ],
      "tags": ["fantasy", "adventure", "coming-of-age"],
      "children": [
        {
          "metadata": { "formatVersion": "1.2" },
          "id": "chapter-1",
          "type": "chapter",
          "name": "The Beginning",
          "body": "It was a dark and stormy night when Elena first discovered the ancient map...",
          "attributes": [
            { "key": "word_count", "value": 3500, "dataType": "int" }
          ]
        },
        {
          "include": "./characters/elena.codex.yaml"
        }
      ]
    }
  ]
}
